# Authentication Service Configuration

# --- Server Settings ---
PORT=3000
NODE_ENV=development
SESSION_SECRET=your-secure-session-secret-here

# --- WebAuthn / Passkeys ---
# rpID: The domain name (e.g. localhost or example.com)
RP_ID=localhost
# origin: The full URL (including protocol and port)
ORIGIN=http://localhost:3000
# rpName: Human readable app name
RP_NAME="Express Easy Auth Demo"

# --- Storage ---
# Path to the SQLite database
DATABASE_PATH=./data/auth.db
mkdirp=true
